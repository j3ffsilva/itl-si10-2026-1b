% ============================================================
% PALETA DE CORES
% ============================================================

\definecolor{bgDark}   {HTML}{382D61}  % Roxo escuro — fundo dos slides escuros
\definecolor{stripe}   {HTML}{303030}  % Cinza escuro — textos e faixa inferior
\definecolor{accent}   {HTML}{303030}  % Linha de separação da faixa inferior
\definecolor{textMuted}{HTML}{FFFFFF}  % Branco — texto secundário na faixa
\definecolor{textDim}  {HTML}{8C85B0}  % Roxo claro — texto apagado
\definecolor{bgLightGreen}  {HTML}{A8DADC}  % Verde-água - fundo de divisões de seção
\definecolor{codegreen}{RGB}{0,120,80}

% ============================================================
% DEFINE JavaScript
% ============================================================

\lstdefinelanguage{JavaScript}{
  keywords={const,let,var,function,return,if,else,for,while,of,in},
  sensitive=true,
  comment=[l]{//},
  morestring=[b]",
  morestring=[b]',
}

% ============================================================
% BEAMER: LIMPEZA DE ELEMENTOS PADRÃO
% ============================================================

\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{headline}{}
\setbeamertemplate{footline}{}
